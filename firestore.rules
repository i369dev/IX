rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to content, but only a specific admin can write.
    match /content/{document} {
      allow read: if true;
      // CRITICAL: Replace 'ADMIN_USER_ID' with the actual UID of your admin user from the Firebase Console (Authentication > Users).
      // This rule restricts database write access to only the designated admin user, preventing unauthorized modifications.
      allow write: if request.auth != null && request.auth.uid == 'ADMIN_USER_ID';
    }
  }
}
