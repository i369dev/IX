{
  "entities": {
    "landingPage": {
      "title": "Landing Page Content",
      "description": "All editable content for the main landing page.",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "description": "Hero section content.",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "titleColor": { "type": "string" },
            "subtitleColor": { "type": "string" }
          },
          "required": ["title", "subtitle"]
        },
        "about": {
          "type": "object",
          "description": "About section content.",
          "properties": {
            "title": { "type": "string" },
            "p1": { "type": "string" },
            "p2": { "type": "string" },
            "titleColor": { "type": "string" },
            "textColor": { "type": "string" }
          },
          "required": ["title", "p1", "p2"]
        },
        "live": {
          "type": "object",
          "description": "Live session video.",
          "properties": {
            "title": {
              "type": "string"
            },
            "videoUrl": {
              "type": "string",
              "format": "uri"
            },
            "titleColor": { "type": "string" }
          },
          "required": [
            "title"
          ]
        },
        "releases": {
          "type": "object",
          "description": "Releases section content.",
          "properties": {
            "title": { "type": "string" },
            "tracks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "duration": { "type": "string" }
                },
                "required": ["name", "duration"]
              }
            },
            "titleColor": { "type": "string" },
            "textColor": { "type": "string" }
          },
          "required": ["title", "tracks"]
        },
        "connect": {
          "type": "object",
          "description": "Connect section content.",
          "properties": {
            "title": { "type": "string" },
            "links": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "icon": { "type": "string" },
                  "url": { "type": "string", "format": "uri" }
                },
                "required": ["icon", "url"]
              }
            },
            "titleColor": { "type": "string" },
            "textColor": { "type": "string" }
          },
          "required": ["title", "links"]
        },
        "footer": {
            "type": "object",
            "description": "Footer content.",
            "properties": {
                "text": { "type": "string" },
                "textColor": { "type": "string" }
            },
            "required": ["text"]
        },
        "maintenanceMode": {
            "type": "boolean",
            "description": "Toggles site maintenance mode. If true, a maintenance page is shown."
        }
      }
    }
  },
  "auth": {
    "providers": ["email-password"]
  },
  "firestore": {
    "/content/{contentId}": {
      "schema": { "$ref": "#/entities/landingPage" },
      "description": "Stores the dynamic content for the website."
    }
  }
}
